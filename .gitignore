# ── dependencies ──
node_modules/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── build outputs ──
.next/
out/
build/
dist/
.turbo/

# ── tests ──
coverage/
.nyc_output/

# ── logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── environment / secrets — NEVER COMMIT ──
.env
.env.*
!.env.example

# ── OS / IDE ──
.DS_Store
.vscode/
.idea/
*.swp

# ── vercel ──
.vercel/

# ── typescript ──
*.tsbuildinfo

# ── pnpm workspace lockfiles (committed via root, not nested) ──
**/pnpm-lock.yaml
!/pnpm-lock.yaml
