# @autonomux/web — environment variables
#
# Copy to `.env.local` for local dev (gitignored — Next.js convention).
# In Vercel, set these via the project's env panel. NEVER commit real secrets.

# ---------------------------------------------------------------------------
# APP
# ---------------------------------------------------------------------------

# Shipped to the client via `process.env.NEXT_PUBLIC_VERSION`. Also used as
# the OTel `service.version` on every span emitted by the web app.
NEXT_PUBLIC_VERSION=0.1.0

# ---------------------------------------------------------------------------
# OBSERVABILITY (OpenTelemetry — @autonomux/telemetry)
# ---------------------------------------------------------------------------
#
# Loaded by apps/web/instrumentation.ts on the Node runtime (Edge no-ops).
# In production the web app hard-fails at boot if OTEL_EXPORTER_OTLP_ENDPOINT
# is unset. In development, missing endpoint = no-op (no crash, no spans).
#
# See packages/telemetry/.env.example for how to find the Axiom values.

# Full OTLP/HTTP traces endpoint (Axiom: https://api.axiom.co/v1/traces).
OTEL_EXPORTER_OTLP_ENDPOINT=

# Comma-separated k=v headers per OTel spec.
# Axiom example: Authorization=Bearer xaat-...,X-Axiom-Dataset=autonomux-traces
OTEL_EXPORTER_OTLP_HEADERS=

# Optional resource attribute overrides per OTel spec (k=v,k=v).
# OTEL_RESOURCE_ATTRIBUTES=

# Deployment env tag. One of: development | staging | production
DEPLOYMENT_ENV=development

# ---------------------------------------------------------------------------
# SUPABASE (Phase 1.0-B1 auth)
# ---------------------------------------------------------------------------
#
# Public — shipped in the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...anon...

# Server-only — bypasses RLS. Guarded by `import "server-only"`.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service_role...

# ---------------------------------------------------------------------------
# SITE URL (Phase 1.0-B1 — used as Supabase emailRedirectTo)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# RATE LIMITER (Upstash Redis — Phase 1.0-B8)
# ---------------------------------------------------------------------------
#
# Either form accepted by apps/web/lib/rate-limit.ts:
#   redis://default:<token>@<host>:<port>      (Upstash connection string)
#   https://<region>-<name>.upstash.io         (REST URL — pair with the token below)
#
# In production REDIS_URL is REQUIRED. In dev, missing → no-op limiter.
REDIS_URL=

# Required only when REDIS_URL is the https:// REST form.
UPSTASH_REDIS_REST_TOKEN=
