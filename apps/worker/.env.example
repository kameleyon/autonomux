# @autonomux/worker — environment variables
#
# Copy to `.env` for local dev (gitignored). In Railway, set these via
# the project's variables panel. NEVER commit real secrets.

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# Redis connection (Upstash in prod, local docker for dev).
# Format: redis://default:<password>@<host>:<port>
# Local:  redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Runtime selector. One of: development | test | staging | production
NODE_ENV=development

# ---------------------------------------------------------------------------
# OPTIONAL
# ---------------------------------------------------------------------------

# Pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Service tag emitted on every log line (used by Axiom).
SERVICE_NAME=autonomux-worker

# ---------------------------------------------------------------------------
# OBSERVABILITY (OpenTelemetry — @autonomux/telemetry)
# ---------------------------------------------------------------------------
#
# In production the worker hard-fails at boot if OTEL_EXPORTER_OTLP_ENDPOINT
# is unset (silent observability loss is unacceptable).
# In development, missing endpoint = no-op (no crash, no spans).
#
# See packages/telemetry/.env.example for how to find the Axiom values.

# Full OTLP/HTTP traces endpoint (Axiom: https://api.axiom.co/v1/traces).
OTEL_EXPORTER_OTLP_ENDPOINT=

# Comma-separated k=v headers per OTel spec.
# Axiom example: Authorization=Bearer xaat-...,X-Axiom-Dataset=autonomux-traces
OTEL_EXPORTER_OTLP_HEADERS=

# Optional resource attribute overrides per OTel spec (k=v,k=v).
# OTEL_RESOURCE_ATTRIBUTES=

# Deployment env tag. One of: development | staging | production
DEPLOYMENT_ENV=development
