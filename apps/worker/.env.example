# @autonomux/worker — environment variables
#
# Copy to `.env` for local dev (gitignored). In Railway, set these via
# the project's variables panel. NEVER commit real secrets.

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# Redis connection (Upstash in prod, local docker for dev).
# Format: redis://default:<password>@<host>:<port>
# Local:  redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Runtime selector. One of: development | test | staging | production
NODE_ENV=development

# ---------------------------------------------------------------------------
# OPTIONAL
# ---------------------------------------------------------------------------

# Pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Service tag emitted on every log line (used by Axiom).
SERVICE_NAME=autonomux-worker
