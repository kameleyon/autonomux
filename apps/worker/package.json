{
  "name": "@autonomux/worker",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomux — background worker. BullMQ-driven queue runner for AlterEgo sub-agents (Mailroom, Scheduler, Scribe, Oracle, Treasurer, Briefing, Audit, Cron). Deployed to Railway.",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@autonomux/logger": "*",
    "@autonomux/telemetry": "*",
    "bullmq": "5.34.10",
    "ioredis": "5.4.2",
    "pino": "9.5.0",
    "dotenv": "8.6.0"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "tsx": "4.19.2",
    "typescript": "5.8.2"
  }
}
