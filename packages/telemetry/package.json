{
  "name": "@autonomux/telemetry",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomux — OpenTelemetry tracing setup. One source of truth for spans, exporters, and LLM-call instrumentation. Exporter target: Axiom OTLP/HTTP.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./sdk": "./src/sdk.ts",
    "./tracer": "./src/tracer.ts",
    "./spans": "./src/spans.ts",
    "./llm": "./src/llm.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "echo '(no lint configured for @autonomux/telemetry yet)'",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.218.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-node": "0.218.0",
    "@opentelemetry/semantic-conventions": "1.41.1"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "typescript": "5.8.2"
  }
}
