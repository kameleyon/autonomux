# @autonomux/telemetry — environment variables
#
# Copy the relevant subset to apps/web/.env and apps/worker/.env for
# local dev (both gitignored). In Railway + Vercel, set these via the
# project's env panel. NEVER commit real tokens.

# ---------------------------------------------------------------------------
# REQUIRED IN PRODUCTION (the SDK hard-fails at boot if missing in prod)
# ---------------------------------------------------------------------------

# Full OTLP/HTTP traces endpoint.
#   Axiom:        https://api.axiom.co/v1/traces
#   Tempo/Jaeger: https://<host>:4318/v1/traces
#
# To find the Axiom endpoint:
#   1. Sign in to https://app.axiom.co
#   2. Settings → API Tokens → create token with `ingest` permission
#      against your traces dataset
#   3. Endpoint is documented under Settings → OpenTelemetry → OTLP/HTTP
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.axiom.co/v1/traces

# Comma-separated k=v header list per OTel spec.
# For Axiom you need an Authorization header + a target dataset header.
#   Format: Authorization=Bearer <token>,X-Axiom-Dataset=<dataset>
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer xaat-REPLACE-ME,X-Axiom-Dataset=autonomux-traces

# ---------------------------------------------------------------------------
# RECOMMENDED
# ---------------------------------------------------------------------------

# Deployment environment tag. Honored as deployment.environment on every
# span so staging spans don't pollute production dashboards.
# One of: development | staging | production
DEPLOYMENT_ENV=development

# ---------------------------------------------------------------------------
# OPTIONAL
# ---------------------------------------------------------------------------

# Extra resource attributes per OTel spec — comma-separated k=v pairs.
# Honored by the SDK natively. Useful for region / cluster tagging.
# OTEL_RESOURCE_ATTRIBUTES=region=us-east-1,cluster=prod-1

# OTel SDK internal log level. Set to `debug` to see why spans aren't
# arriving. Off by default.
# Values: none | error | warn | info | debug | verbose
# OTEL_LOG_LEVEL=debug
