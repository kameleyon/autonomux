# @autonomux/logger — runtime configuration.
#
# These vars are READ by createLogger() at boot. See README.md for usage.
# Local dev: copy to .env in the consuming app (apps/web, apps/worker,
# apps/admin) — this package does not load dotenv itself.

# Axiom (system log — PRD §8.2). Without these, prod logs go to stdout
# only (Vercel/Railway scrape stdout, so logs are still captured).
AXIOM_TOKEN=
AXIOM_DATASET=autonomux-prod

# Pino log level. Valid: fatal | error | warn | info | debug | trace.
# Defaults to "info" when unset.
LOG_LEVEL=info
