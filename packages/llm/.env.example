# @autonomux/llm — environment variables
#
# Set LLM_PROVIDER to switch between providers without code changes.
# OpenRouter is the v1 default.

# Provider selector — "openrouter" (default) or "anthropic"
LLM_PROVIDER=openrouter

# Required when LLM_PROVIDER=openrouter
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=__YOUR_OPENROUTER_KEY_HERE__

# Required when LLM_PROVIDER=anthropic
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=__YOUR_ANTHROPIC_KEY_HERE__
