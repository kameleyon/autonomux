{
  "name": "@autonomux/llm",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomux — pluggable LLM adapter. OpenRouter default, Anthropic direct via env-var swap. Owned by [Forge].",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./client": "./src/client.ts",
    "./pricing": "./src/pricing.ts",
    "./errors": "./src/errors.ts",
    "./budget": "./src/util/budget.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo '(no lint configured for @autonomux/llm yet)'",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.65.0",
    "pino": "9.5.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "typescript": "5.8.2",
    "vitest": "2.1.8"
  }
}
