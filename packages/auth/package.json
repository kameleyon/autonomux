    "lint": "echo '(no lint configured for @autonomux/auth yet)'",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@autonomux/cipher": "*",
    "@autonomux/db": "*",
    "@otplib/core": "12.0.1",
    "@simplewebauthn/server": "11.0.0",
    "@simplewebauthn/types": "11.0.0",
    "otplib": "12.0.1",
    "qrcode": "1.5.4",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/qrcode": "1.5.5",
    "typescript": "5.8.2",
    "vitest": "2.1.8"
  }
}
