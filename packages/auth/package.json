{
  "name": "@autonomux/auth",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomux — TOTP + WebAuthn 2FA primitives. Owned by [Cipher + Shield].",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./totp": "./src/totp.ts",
    "./webauthn": "./src/webauthn.ts",
    "./backup-codes": "./src/backup-codes.ts",
    "./rate-limit": "./src/rate-limit.ts",
    "./step-up": "./src/step-up.ts",
    "./two-fa-session": "./src/two-fa-session.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run",
