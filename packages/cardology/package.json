{
  "name": "@autonomux/cardology",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomux — Sacred-Symbols cardology engine + Western astrology (Swiss-Ephemeris-grade) planet positions, houses, aspects. Pure JS — no native deps. Owned by [Oracle].",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./cardology": "./src/cardology/engine.ts",
    "./cardology/data": "./src/cardology/data.ts",
    "./astro": "./src/astro/birth-chart.ts",
