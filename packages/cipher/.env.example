# @autonomux/cipher — required environment variables
#
# Copy to .env.local (NEVER commit a real .env) and fill in values from Doppler.
# In production, prefer IAM-role credentials over static keys (omit AWS_ACCESS_*).

# --- AWS KMS ---
# Region where the CMK lives. One region per environment (us-east-1 prod, etc.)
AWS_REGION=us-east-1

# The KMS CMK we wrap DEKs with. Use a key alias, not a raw key id, so we can
# rotate the underlying material without redeploying. Per environment, create a
# distinct CMK with its own key policy (least privilege; only the app role can
# Encrypt/Decrypt).
#
# Example: alias/autonomux-cipher-prod
AWS_KMS_KEY_ID=alias/autonomux-cipher-prod

# --- AWS credentials (LOCAL DEV ONLY) ---
# In production these MUST be omitted; the AWS SDK should resolve credentials
# from the IAM role attached to the container/instance (Fargate task role, EKS
# IRSA, EC2 instance profile, etc.). Static keys in env are a foot-gun.
#
# Uncomment for local development only:
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...   # only if using STS short-lived credentials
