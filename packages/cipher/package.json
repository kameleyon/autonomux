{
  "name": "@autonomux/cipher",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomux — Envelope encryption + KMS + libsodium AEAD + PII redaction. Owned by [Cipher].",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./envelope": "./src/envelope.ts",
    "./kms": "./src/kms.ts",
    "./redact": "./src/redact.ts",
    "./types": "./src/types.ts",
    "./utils": "./src/utils.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo '(no lint configured for @autonomux/cipher yet)'",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "3.726.0",
    "libsodium-wrappers-sumo": "0.7.15",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/libsodium-wrappers-sumo": "0.7.8",
    "@types/node": "22.10.5",
    "typescript": "5.8.2",
    "vitest": "2.1.8"
  }
}
